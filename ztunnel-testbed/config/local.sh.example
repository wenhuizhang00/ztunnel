# =============================================================================
# Local overrides - copy to local.sh and customize
# =============================================================================
# cp config/local.sh.example config/local.sh
# =============================================================================

# Istio
# ISTIO_VERSION="1.29.0"
# GATEWAY_API_VERSION="v1.4.0"
# ISTIO_PLATFORM="gke"   # Optional: gke, eks, k3d, minikube

# Cluster
# KUBECONFIG="$HOME/.kube/ztunnel-baremetal-config"  # Point to kubeconfig (e.g. from bare-metal)
# KUBE_CONTEXT="my-context"   # Optional: kubectl context to use

# Sample app namespaces (default: grimlock, grimlock-baseline)
# APP_NAMESPACE="grimlock"
# APP_NAMESPACE_BASELINE="grimlock-baseline"

# Proxy (when behind corporate proxy - add CIDRs so kubeadm bypasses proxy)
# NO_PROXY="localhost,127.0.0.1,10.96.0.0/12,192.168.0.0/16"
# Or extend: NO_PROXY="${NO_PROXY},10.200.0.0/16"  # control-plane/node IPs

# Bare metal (when using make create-baremetal)
# CNI_PROVIDER="calico"       # calico (default) | cilium
# CILIUM_VERSION="1.16.0"    # When CNI_PROVIDER=cilium
# K8S_VERSION="1.30.0"
# POD_NETWORK_CIDR="192.168.0.0/16"
# CALICO_VERSION="v3.28.0"
# CRI_SOCKET="unix:///var/run/containerd/containerd.sock"
# CONTROL_PLANE_ENDPOINT=""  # For HA: "ip-or-hostname:6443"
